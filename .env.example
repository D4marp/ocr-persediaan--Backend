APP_PORT=8080

# Database
DB_HOST=mysql
DB_PORT=3306
DB_USER=user
DB_PASSWORD=password
DB_NAME=persediaan_db

PROCESSING_SERVICE_URL=http://127.0.0.1:8090
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# docker-compose.yml host port overrides (optional - defaults shown below).
# Set these if 8080/3000/3307 are already used by something else on the host.
BACKEND_PORT=8080
FRONTEND_PORT=3000
MYSQL_HOST_PORT=3307
PUBLIC_API_URL=http://localhost:8080/api/v1
